NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/pawcare
JWT_SECRET=replace-with-a-long-random-secret

# Firebase Admin SDK for Google OAuth token verification and FCM push
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./serviceAccountKey.json

# Required for email OTP verification and NGO email alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-gmail-app-password
NOTIFICATION_FROM="PawCare <your-gmail-address@gmail.com>"

# Optional SMS alerts through Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Alert fan-out controls
OTP_TTL_MINUTES=10
NGO_NOTIFY_LIMIT=10
